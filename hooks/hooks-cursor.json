{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CURSOR_PLUGIN_ROOT}/hooks/session-start",
            "async": false
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CURSOR_PLUGIN_ROOT}/hooks/destructive-warning.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CURSOR_PLUGIN_ROOT}/hooks/tdd-reminder.sh"
          },
          {
            "type": "command",
            "command": "${CURSOR_PLUGIN_ROOT}/hooks/brand-check.sh"
          }
        ]
      }
    ]
  }
}
